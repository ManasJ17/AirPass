# Node dependencies
node_modules/

# Temporary files created by npm/yarn
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Runtime data
logs/
*.log
pids/
*.pid
*.seed
*.pid.lock

# Environment files (secrets)
.env
.env.*

# Uploads folder (temporary file storage)
uploads/

# Build and distribution folders
dist/
build/
out/
coverage/
*.tgz

# Cache folders
.cache/
.parcel-cache/
.next/
.nuxt/
/.vite/

# OS generated files
.DS_Store
Thumbs.db
desktop.ini
Icon?
ehthumbs.db

# IDE / editor folders and files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln

# Editor temporary files
*~
*.swp
*.swo
# VS Code workspace storage
.vscode/*

# Temporary and backup files
*.tmp
*.temp
*.bak
*.orig

# Lock files used by package managers (keep if you use them; uncomment to ignore)
# package-lock.json
# yarn.lock

# Optional: keep an uploads placeholder in repo if needed
# If you want to keep an empty `uploads/` folder in the repo, create an
# empty file called `uploads/.gitkeep` and remove or comment out the rule above.
